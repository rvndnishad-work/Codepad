{
  "base": "vs-dark",
  "inherit": true,
  "rules": [
    { "background": "193549", "foreground": "ffffff", "token": "" },

    { "foreground": "0088ff", "fontStyle": "italic", "token": "comment" },
    { "foreground": "0088ff", "fontStyle": "italic", "token": "comment.line" },
    { "foreground": "0088ff", "fontStyle": "italic", "token": "comment.block" },

    { "foreground": "ff628c", "token": "constant" },
    { "foreground": "ff628c", "token": "number" },
    { "foreground": "ff628c", "token": "number.float" },
    { "foreground": "ff628c", "token": "number.hex" },
    { "foreground": "ff628c", "token": "constant.numeric" },

    { "foreground": "ffc600", "token": "entity" },
    { "foreground": "ffc600", "token": "entity.name" },
    { "foreground": "ffc600", "token": "entity.name.function" },
    { "foreground": "9effff", "token": "entity.name.tag" },
    { "foreground": "ffc600", "fontStyle": "italic", "token": "entity.other.attribute-name" },
    { "foreground": "ffc600", "fontStyle": "italic", "token": "entity.other.attribute-name.html" },
    { "foreground": "ffc600", "fontStyle": "italic", "token": "entity.other.attribute-name.jsx" },
    { "foreground": "ffc600", "fontStyle": "italic", "token": "entity.other.attribute-name.tsx" },

    { "foreground": "f44542", "token": "invalid" },

    { "foreground": "ff9d00", "token": "keyword" },
    { "foreground": "ff9d00", "token": "keyword.control" },
    { "foreground": "ff9d00", "fontStyle": "italic", "token": "keyword.control.export" },
    { "foreground": "ff9d00", "token": "keyword.operator" },
    { "foreground": "ff9d00", "token": "keyword.other" },

    { "foreground": "ffc600", "token": "storage" },
    { "foreground": "ffc600", "token": "storage.type" },
    { "foreground": "ff9d00", "token": "storage.type.class" },
    { "foreground": "fb94ff", "token": "storage.type.function" },
    { "foreground": "ffc600", "token": "storage.type.function.arrow" },
    { "foreground": "ffc600", "token": "storage.modifier" },

    { "foreground": "a5ff90", "token": "string" },
    { "foreground": "a5ff90", "token": "string.quoted" },
    { "foreground": "92fc79", "token": "punctuation.definition.string" },
    { "foreground": "3ad900", "token": "string.template" },
    { "foreground": "3ad900", "token": "punctuation.definition.string.template" },

    { "foreground": "80ffbb", "token": "support" },
    { "foreground": "ff9d00", "token": "support.function" },
    { "foreground": "e1efff", "token": "support.variable.property.dom" },

    { "foreground": "e1efff", "token": "variable" },
    { "foreground": "e1efff", "token": "variable.other" },
    { "foreground": "fb94ff", "token": "variable.language" },

    { "foreground": "9effff", "token": "meta" },
    { "foreground": "e1efff", "token": "meta.brace" },
    { "foreground": "e1efff", "token": "punctuation" },
    { "foreground": "ffee80", "token": "punctuation.definition.parameters" },
    { "foreground": "ffee80", "token": "punctuation.definition.template-expression" },

    { "foreground": "80ffbb", "token": "type" },
    { "foreground": "80ffbb", "token": "type.identifier" },
    { "foreground": "80ffbb", "token": "entity.name.type" },
    { "foreground": "fb94ff", "token": "entity.name.class" },
    { "foreground": "fb94ff", "token": "entity.name.type.class" },

    { "foreground": "ffffff", "token": "identifier" },
    { "foreground": "ffc600", "token": "function" },
    { "foreground": "ffc600", "token": "attribute.name" },
    { "foreground": "a5ff90", "token": "attribute.value" },
    { "foreground": "e1efff", "token": "delimiter" },
    { "foreground": "e1efff", "token": "delimiter.bracket" },
    { "foreground": "e1efff", "token": "delimiter.parenthesis" },
    { "foreground": "e1efff", "token": "delimiter.square" },
    { "foreground": "e1efff", "token": "delimiter.angle" },
    { "foreground": "ff9d00", "token": "operator" },
    { "foreground": "9effff", "token": "tag" },
    { "foreground": "9effff", "token": "tag.html" },
    { "foreground": "9effff", "token": "tag.xml" },
    { "foreground": "9effff", "token": "metatag" },
    { "foreground": "9effff", "token": "metatag.html" },
    { "foreground": "ff628c", "token": "regexp" },
    { "foreground": "ffee80", "token": "constant.language" },
    { "foreground": "ffee80", "token": "predefined" },

    { "foreground": "a5ff90", "token": "markup.inserted" },
    { "foreground": "ff628c", "token": "markup.deleted" },
    { "foreground": "967efb", "token": "markup.changed" },
    { "foreground": "ffc600", "fontStyle": "bold", "token": "markup.heading" },
    { "foreground": "9effff", "fontStyle": "bold", "token": "markup.bold" },
    { "foreground": "9effff", "fontStyle": "italic", "token": "markup.italic" }
  ],
  "colors": {
    "editor.foreground": "#ffffff",
    "editor.background": "#193549",
    "editor.selectionBackground": "#0050A4",
    "editor.selectionHighlightBackground": "#0050A480",
    "editor.lineHighlightBackground": "#1F4662",
    "editor.lineHighlightBorder": "#234E6D",
    "editor.rangeHighlightBackground": "#1F4662",
    "editor.findMatchBackground": "#FF720066",
    "editor.findMatchHighlightBackground": "#CAD40F66",
    "editor.findRangeHighlightBackground": "#243E51",
    "editor.hoverHighlightBackground": "#ffc60033",
    "editor.inactiveSelectionBackground": "#003b8b",
    "editor.wordHighlightBackground": "#ffffff21",
    "editor.wordHighlightStrongBackground": "#ffffff21",

    "editorCursor.foreground": "#ffc600",
    "editorWhitespace.foreground": "#ffffff52",
    "editorIndentGuide.background": "#3B5364",
    "editorIndentGuide.activeBackground": "#ffc60050",

    "editorLineNumber.foreground": "#aaaaaa",
    "editorLineNumber.activeForeground": "#ffffff",
    "editorBracketMatch.background": "#0d3a58",
    "editorBracketMatch.border": "#ffc60080",

    "editorBracketHighlight.foreground1": "#FFA500",
    "editorBracketHighlight.foreground2": "#FF69B4",
    "editorBracketHighlight.foreground3": "#00FF7F",
    "editorBracketHighlight.foreground4": "#00FFFF",
    "editorBracketHighlight.foreground5": "#FFD700",
    "editorBracketHighlight.foreground6": "#FF00FF",

    "editorGutter.background": "#12273866",
    "editorGutter.modifiedBackground": "#ffc600",
    "editorGutter.addedBackground": "#3C9F4A",
    "editorGutter.deletedBackground": "#A22929",

    "editorOverviewRuler.border": "#0d3a58",
    "editorOverviewRuler.errorForeground": "#A22929",
    "editorOverviewRuler.warningForeground": "#ffc600",

    "editorError.foreground": "#A22929",
    "editorError.border": "#0d3a58",
    "editorWarning.foreground": "#ffc600",
    "editorWarning.border": "#ffffff00",
    "editorHint.foreground": "#ffc600",
    "editorInfo.foreground": "#0088ff",

    "editorWidget.background": "#15232d",
    "editorWidget.border": "#0d3a58",
    "editorWidget.foreground": "#aaa",

    "editorSuggestWidget.background": "#15232d",
    "editorSuggestWidget.border": "#15232d",
    "editorSuggestWidget.foreground": "#aaa",
    "editorSuggestWidget.highlightForeground": "#ffc600",
    "editorSuggestWidget.selectedBackground": "#193549",
    "editorSuggestWidget.selectedForeground": "#ffffff",
    "editorSuggestWidget.focusHighlightForeground": "#ffc600",

    "editorHoverWidget.background": "#15232d",
    "editorHoverWidget.border": "#0d3a58",
    "editorHoverWidget.foreground": "#ffffff",

    "input.background": "#193549",
    "input.border": "#0d3a58",
    "input.foreground": "#ffc600",
    "input.placeholderForeground": "#aaa",
    "inputOption.activeBorder": "#8dffff",

    "dropdown.background": "#193549",
    "dropdown.border": "#15232d",
    "dropdown.foreground": "#fff",

    "list.activeSelectionBackground": "#193549",
    "list.activeSelectionForeground": "#aaa",
    "list.hoverBackground": "#193549",
    "list.hoverForeground": "#aaa",
    "list.focusBackground": "#0d3a58",
    "list.focusForeground": "#aaa",
    "list.highlightForeground": "#ffc600",
    "list.inactiveSelectionBackground": "#0d3a58",
    "list.inactiveSelectionForeground": "#aaa",

    "scrollbar.shadow": "#00000000",
    "scrollbarSlider.background": "#406179cc",
    "scrollbarSlider.hoverBackground": "#437da3cc",
    "scrollbarSlider.activeBackground": "#355166cc",

    "minimap.background": "#193549",
    "minimapSlider.background": "#1f466240",

    "peekView.border": "#ffc600",
    "peekViewEditor.background": "#193549",
    "peekViewResult.background": "#15232d",
    "peekViewResult.fileForeground": "#aaa",
    "peekViewResult.lineForeground": "#fff",
    "peekViewResult.matchHighlightBackground": "#0d3a58",
    "peekViewResult.selectionBackground": "#0d3a58",
    "peekViewResult.selectionForeground": "#fff",
    "peekViewTitle.background": "#15232d",
    "peekViewTitleDescription.foreground": "#aaa",
    "peekViewTitleLabel.foreground": "#ffc600",

    "focusBorder": "#0d3a58",
    "foreground": "#aaa",
    "selection.background": "#027dff"
  }
}