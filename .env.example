DATABASE_URL="file:./dev.db"
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_TRUST_HOST=true
# Comma-separated list of emails granted access to /admin/*
ADMIN_EMAILS=""

# Code execution backend (Piston — https://github.com/engineer-man/piston).
# Untrusted playground/challenge code runs ONLY here, never on the app server.
# Point this at your self-hosted Piston instance (e.g. http://piston:2000) or a
# managed endpoint. Optional tuning vars shown with their defaults.
PISTON_URL="http://localhost:2000"
# PISTON_RUN_TIMEOUT=5000        # per-run wall clock (ms)
# PISTON_COMPILE_TIMEOUT=10000   # compile budget (ms)
# PISTON_RUN_MEMORY=268435456    # run memory cap in bytes (-1 = unlimited)
# EXECUTE_MAX_CONCURRENT=8       # max concurrent executor calls per instance

# Comma-separated list of custom WebRTC signaling servers
# NEXT_PUBLIC_SIGNALING_URL="ws://localhost:4444,wss://signaling.yjs.dev"

# Transactional email (Resend — https://resend.com).
# Leave RESEND_API_KEY blank to log emails to the server console instead of
# sending (zero-config dev default). Set it to send for real.
RESEND_API_KEY=""
# Sender. In Resend TEST MODE (real key, but no verified domain) the ONLY
# accepted sender is onboarding@resend.dev, and Resend will only deliver to your
# own Resend account email. Leaving this blank outside production auto-uses the
# test sender. In production, set it to an address on your verified domain.
# EMAIL_FROM="Interviewpad <onboarding@resend.dev>"
# Resend webhook secret (IP-25). Required for /api/webhooks/resend to accept
# delivery / bounce / complaint events. Create the webhook in Resend's
# dashboard pointing at https://<your-domain>/api/webhooks/resend and paste
# the `whsec_…` secret here. Without this set, the route 503s on every POST.
RESEND_WEBHOOK_SECRET=""
