generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String              @id @default(cuid())
  name          String?
  email         String?             @unique
  emailVerified DateTime?
  image         String?
  /// bcrypt hash for credentials login. null when only OAuth is used.
  passwordHash  String?
  /// Optional public profile bio shown on /u/[id] portfolio page.
  bio           String?
  /// Optional "Hire Me" contact (email, URL, etc.) shown on portfolio.
  hireMeUrl     String?
  /// Whether the user wants their portfolio publicly visible.
  portfolioPublic Boolean           @default(true)
  accounts      Account[]
  sessions      Session[]
  snippets      Snippet[]
  attempts      ChallengeAttempt[]
  interviewSessions InterviewSession[]
  /// Challenges the user has authored. null author = admin/curated.
  authoredChallenges Challenge[]      @relation("AuthoredChallenges")
  /// Enrollments + invitations on the unified Challenge model. Replaces the
  /// retired Track equivalents (dropped in Stage 3 cleanup).
  challengeEnrollments  ChallengeEnrollment[]
  challengeInvitations  ChallengeInvitation[] @relation("ChallengeInvitedUser")
  sentChallengeInvites  ChallengeInvitation[] @relation("ChallengeInvitedBy")
  followers     Follow[]            @relation("following")
  following     Follow[]            @relation("follower")
  blogs         BlogPost[]
  blogReactions BlogReaction[]
  blogComments  BlogComment[]
  blogBookmarks BlogBookmark[]
  /// Whether the user is banned from the platform.
  banned        Boolean           @default(false)
  createdAt     DateTime            @default(now())
}

model Follow {
  followerId  String
  followingId String
  follower    User   @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User   @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Snippet {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String   @default("Untitled")
  template   String
  /// JSON map of { "/path": "contents" }
  files      String
  visibility String   @default("private")
  /// JSON-encoded string[] of tag labels
  tags       String?
  pinned     Boolean  @default(false)
  viewCount  Int      @default(0)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([visibility, updatedAt])
  @@index([viewCount])
}

/// A coding challenge with starter code + hidden tests.
/// Difficulty: "easy" | "medium" | "hard". Stored as string for SQLite portability.
model Challenge {
  id              String             @id @default(cuid())
  slug            String             @unique
  title           String
  /// Markdown description shown on the detail page.
  description     String
  /// "easy" | "medium" | "hard"
  difficulty      String             @default("easy")
  /// Sandpack template id (e.g. "test-ts", "react", "vanilla")
  template        String
  /// JSON map of starter files visible/editable to the user.
  starterFiles    String
  /// JSON map of hidden test files (run but not shown to user).
  testFiles       String
  /// JSON-encoded string[] of tag labels (e.g. "arrays", "react", "hooks").
  tags            String?
  /// Estimated time to solve, in minutes. Used for the timer default.
  estimatedMinutes Int               @default(15)
  /// Optional human-readable category (e.g. "Algorithms", "Frontend").
  category        String?
  /// Published challenges show up in the list. Drafts are owner-only.
  published       Boolean            @default(true)
  /// "public" | "private". Only meaningful when published=true; mirrors the
  /// same field on ChallengeTrack (Track is being folded into Challenge in
  /// Stage 2 — keeping the names aligned so the migration is mechanical).
  visibility      String             @default("public")
  /// Staff-pick flag — surfaces a star badge on /challenges and bumps the
  /// challenge to the top of the grid. Admin-only.
  featured        Boolean            @default(false)
  /// Single null author = admin/curated; non-null = user-authored.
  authorId        String?
  author          User?              @relation("AuthoredChallenges", fields: [authorId], references: [id], onDelete: SetNull)
  attempts        ChallengeAttempt[]
  /// Ordered substeps. A "classic" single-question challenge has exactly one
  /// step (auto-created during the Stage 1 backfill). Multi-step challenges
  /// (formerly Tracks) have N steps that the participant walks through.
  steps           ChallengeStep[]
  enrollments     ChallengeEnrollment[]
  invitations     ChallengeInvitation[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([published, featured, difficulty])
  @@index([authorId])
}

/// One ordered step inside a Challenge. Stage 1 introduces this as the new
/// home for the runnable code/tests; the parent Challenge still carries the
/// legacy starterFiles/testFiles/template fields during the transition so
/// no read path breaks before Stage 2 cleans them up.
///
/// Single-step challenges: one ChallengeStep row mirroring the parent.
/// Multi-step challenges (Track replacements): N rows, position 0..N-1.
model ChallengeStep {
  id               String             @id @default(cuid())
  challengeId      String
  challenge        Challenge          @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  position         Int
  /// Optional per-step title — for multi-step challenges this is "Step 1:
  /// Two Sum". Single-step challenges just leave it null and reuse the
  /// parent Challenge title.
  title            String?
  /// Markdown description for this step. Overrides the parent's description
  /// when rendering the step's instructions.
  description      String
  /// Sandpack template id (e.g. "test-ts", "react", "vanilla").
  template         String
  /// JSON map of { "/path": "code" } — visible/editable to the user.
  starterFiles     String
  /// JSON map of { "/path": "code" } — hidden test files.
  testFiles        String
  estimatedMinutes Int                @default(15)
  /// Optional hint, surfaced behind a "Show hint" toggle on the attempt page.
  hint             String?
  /// Optional walkthrough video. YouTube / Vimeo / Loom auto-embed.
  videoUrl         String?
  attempts         ChallengeAttempt[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([challengeId, position])
  @@index([challengeId, position])
}

/// Stage 2 unified enrollment — replaces ChallengeTrackEnrollment once
/// Tracks are folded into Challenges. Same shape, same status state machine.
model ChallengeEnrollment {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId   String
  challenge     Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  /// "active" | "stashed" | "completed" | "abandoned"
  status        String    @default("active")
  startedAt     DateTime  @default(now())
  lastVisitedAt DateTime  @default(now())
  completedAt   DateTime?

  @@unique([userId, challengeId])
  @@index([userId, status])
  @@index([challengeId])
}

/// Stage 2 unified invitation — replaces TrackInvitation. Same magic-link
/// model: opaque token, email-keyed, status state machine.
/// status: "pending" | "accepted" | "revoked"
model ChallengeInvitation {
  id          String     @id @default(cuid())
  challengeId String
  challenge   Challenge  @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  email       String
  userId      String?
  user        User?      @relation("ChallengeInvitedUser", fields: [userId], references: [id], onDelete: SetNull)
  token       String     @unique
  invitedById String?
  invitedBy   User?      @relation("ChallengeInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  status      String     @default("pending")
  acceptedAt  DateTime?
  createdAt   DateTime   @default(now())

  @@unique([challengeId, email])
  @@index([email])
  @@index([userId])
  @@index([challengeId, status])
}

/// A user's relationship to a track. One row per (user, track); state machine
/// driven by user actions. Track progress is computed from ChallengeAttempt
/// rows — we don't denormalise the "solved count" to avoid drift.
/// status: "active" | "stashed" | "completed" | "abandoned"
/// A user's attempt at a challenge.
/// status: "in_progress" | "passed" | "failed" | "abandoned"
model ChallengeAttempt {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  /// Which step inside the challenge this attempt is for. Nullable for
  /// pre-migration rows; populated by the Stage 1 backfill script. New
  /// attempts MUST set this.
  stepId      String?
  step        ChallengeStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)
  status      String    @default("in_progress")
  /// JSON map of the user's final submitted files (excluding hidden tests).
  files       String?
  /// JSON-encoded test results: { tests: [{name, status, error?}], passed, total }
  testResults String?
  /// Total elapsed seconds at submission.
  durationSec Int?
  /// Optional reference to the parent interview session.
  sessionId   String?
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?

  @@index([userId, status])
  @@index([challengeId])
  @@index([sessionId])
}

/// An interview session: a sequence of challenges with a hard time limit.
/// status: "scheduled" | "in_progress" | "completed" | "abandoned"
model InterviewSession {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String   @default("Interview Session")
  candidateName String?
  type          String   @default("mock") // "mock" | "live"
  verdict       String?  // "success" | "failed" | "left_in_between" | "suspicious"
  notes         String?
  creatorRole   String   @default("candidate") // "interviewer" | "candidate"
  /// Set when a guest candidate requests the interviewer to start the session.
  startRequestedAt DateTime?
  /// JSON-encoded string[] of challenge IDs, in order.
  challengeIds  String
  /// Tracks the ID of the challenge currently being worked on
  activeChallengeId String?
  /// Hard time limit for the whole session, in seconds.
  totalSec      Int
  status        String   @default("scheduled")
  /// Random token used to grant read-only "interviewer view" access.
  shareToken    String   @unique
  /// A friendly 4-digit access code (e.g., "4921")
  shortCode     String?  @unique
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([userId, status])
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?
  content     String   // Markdown content
  coverImage  String?
  published   Boolean  @default(false)
  viewCount   Int      @default(0)
  /// JSON-encoded string[] of tag labels (e.g. "react", "typescript", "ai").
  tags        String?
  /// "DRAFT" | "PENDING" | "PUBLISHED" | "REJECTED" | "NEEDS_CHANGES"
  status      String   @default("DRAFT")
  /// Feedback from admin if changes are needed or rejection reason.
  adminNotes  String?
  /// Admin-only flag for staff-picked / featured posts.
  featured    Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions   BlogReaction[]
  comments    BlogComment[]
  bookmarks   BlogBookmark[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([published, createdAt])
  @@index([featured, createdAt])
}

/// A reaction to a blog post (clap, heart, etc.). Type lets us extend later
/// without another model. One row per (post, user, type).
model BlogReaction {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// "clap" for v1. Future: "heart", "fire", "unicorn".
  type      String   @default("clap")
  createdAt DateTime @default(now())

  @@unique([postId, userId, type])
  @@index([postId])
  @@index([userId])
}

/// A comment on a blog post. parentId enables threading — currently flat in UI.
model BlogComment {
  id        String        @id @default(cuid())
  postId    String
  post      BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    BlogComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   BlogComment[] @relation("CommentReplies")
  content   String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([postId, createdAt])
  @@index([userId])
}

/// Saved-for-later bookmarks. Composite PK avoids duplicate saves.
model BlogBookmark {
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([postId, userId])
  @@index([userId, createdAt])
}

model SiteSetting {
  key   String @id
  value String // JSON-encoded configuration
}
