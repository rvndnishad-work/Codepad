# ─────────────────────────────────────────────────────────────────────────────
# Codepad environment. Copy to `.env` and fill in. NEVER commit a real `.env`.
# Vars are grouped REQUIRED (app won't run / core features break without them)
# vs OPTIONAL (feature-gated — set only the integrations you use).
# See DEPLOY.md for the production (Vercel + Fly) setup.
# ─────────────────────────────────────────────────────────────────────────────

# ===== REQUIRED: Database (Postgres) =========================================
# Pooled connection used at runtime. On Vercel Postgres set this to the value of
# POSTGRES_PRISMA_URL. For local dev, point at a local/remote Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/codepad?schema=public"
# Direct (non-pooling) connection used by `prisma migrate`. On Vercel Postgres
# set this to POSTGRES_URL_NON_POOLING. Locally it can equal DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/codepad?schema=public"

# ===== REQUIRED: Auth (NextAuth v5) ==========================================
# Generate with: openssl rand -base64 32   (use a FRESH value in production)
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true
# Public site origin. In production set both to your https://<app>.vercel.app URL
# (or custom domain). Drives auth callbacks, absolute links, email URLs.
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Comma-separated list of emails granted access to /admin/*
ADMIN_EMAILS=""

# ===== REQUIRED: Encryption ==================================================
# AES-GCM key (base64 of 32 random bytes) for TOTP secrets + MCP auth tokens at
# rest. Generate with: openssl rand -base64 32
# Set ONCE — rotating it invalidates all existing ciphertext (2FA, MCP tokens).
ENCRYPTION_KEY_BASE64=""

# ===== REQUIRED: Cron auth ===================================================
# Protects /api/cron/* (Vercel Cron sends this as a bearer). 32-byte hex:
#   openssl rand -hex 32
CRON_SECRET=""

# ===== REQUIRED: Code execution (Piston) =====================================
# Untrusted playground/challenge code runs ONLY here, never on the app server.
# Local dev: http://localhost:2000 (docker-compose.piston.yml).
# Production: your Ubuntu droplet Piston endpoint behind the Caddy auth proxy
# (https://piston.yourdomain.com). See deploy/piston/DROPLET.md. Not Vercel/Fly.
PISTON_URL="http://localhost:2000"
# Shared bearer sent on every Piston request. REQUIRED in production: the Fly
# deploy exposes Piston behind an auth proxy (Piston has no auth of its own) and
# rejects requests without this token. Leave blank for local docker (no proxy).
#   openssl rand -hex 32
PISTON_AUTH_TOKEN=""
# Optional tuning (defaults shown). PISTON_RUN_TIMEOUT MUST be <= the Piston
# server's own configured max or every request 400s.
# PISTON_RUN_TIMEOUT=3000        # per-run wall clock (ms)
# PISTON_COMPILE_TIMEOUT=10000   # compile budget (ms)
# PISTON_RUN_MEMORY=268435456    # run memory cap in bytes (-1 = unlimited)
# EXECUTE_MAX_CONCURRENT=8       # max concurrent executor calls per instance
# JUDGE_MAX_CONCURRENT=4         # max concurrent challenge-judge runs per instance

# ===== RECOMMENDED on Vercel: Upstash Redis ==================================
# Distributed rate limiting + execute result cache. Without it each serverless
# instance has its own in-memory limiter/cache (incorrect across instances).
# Strongly recommended for any multi-instance/serverless deploy. https://upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# EXECUTE_CACHE_TTL=300          # execute result cache TTL in seconds

# ===== OPTIONAL: AI — Gemini / Gemma (interviewer + admin copilot) ===========
GEMINI_API_KEY=""
# GOOGLE_API_KEY=""              # fallback name some routes also accept
# AI_INTERVIEW_GEMINI_MODEL=""   # override default interviewer model
# ADMIN_COPILOT_MODEL=""         # override default admin copilot model

# ===== OPTIONAL: AI — OpenAI (TTS) ===========================================
OPENAI_API_KEY=""
# OPENAI_TTS_MODEL=tts-1-hd
# OPENAI_TTS_VOICE=nova

# ===== OPTIONAL: Voice — ElevenLabs ==========================================
ELEVENLABS_API_KEY=""
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL=eleven_flash_v2_5

# ===== OPTIONAL: Realtime voice/video — LiveKit ==============================
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# ===== OPTIONAL: Transactional email (Resend) ================================
# Leave RESEND_API_KEY blank to log emails to the server console instead of
# sending. In Resend TEST MODE (real key, unverified domain) the only accepted
# sender is onboarding@resend.dev and delivery is limited to your Resend email.
RESEND_API_KEY=""
# EMAIL_FROM="Interviewpad <onboarding@resend.dev>"   # set on a verified domain in prod
# Resend webhook secret (whsec_…). Required only for /api/webhooks/resend.
RESEND_WEBHOOK_SECRET=""

# ===== OPTIONAL: Billing (Stripe) ============================================
# Set when enabling paid credits/billing. Webhook secret for /api/webhooks/stripe.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ===== OPTIONAL: OAuth providers (set per provider you enable) ===============
# Callback URLs must point at your deployed origin, e.g.
#   https://<app>.vercel.app/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""

# ===== OPTIONAL: Collaborative editing (Yjs WebRTC signaling) ================
# Comma-separated custom signaling servers. Defaults to public yjs signaling.
# NEXT_PUBLIC_SIGNALING_URL="ws://localhost:4444,wss://signaling.yjs.dev"
