generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String              @id @default(cuid())
  name          String?
  email         String?             @unique
  emailVerified DateTime?
  image         String?
  /// bcrypt hash for credentials login. null when only OAuth is used.
  passwordHash  String?
  /// Optional public profile bio shown on /u/[id] portfolio page.
  bio           String?
  /// Optional "Hire Me" contact (email, URL, etc.) shown on portfolio.
  hireMeUrl     String?
  /// Whether the user wants their portfolio publicly visible.
  portfolioPublic Boolean           @default(true)
  accounts      Account[]
  sessions      Session[]
  snippets      Snippet[]
  attempts      ChallengeAttempt[]
  interviewSessions InterviewSession[]
  followers     Follow[]            @relation("following")
  following     Follow[]            @relation("follower")
  blogs         BlogPost[]
  blogReactions BlogReaction[]
  blogComments  BlogComment[]
  blogBookmarks BlogBookmark[]
  createdAt     DateTime            @default(now())
}

model Follow {
  followerId  String
  followingId String
  follower    User   @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User   @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Snippet {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String   @default("Untitled")
  template   String
  /// JSON map of { "/path": "contents" }
  files      String
  visibility String   @default("private")
  /// JSON-encoded string[] of tag labels
  tags       String?
  pinned     Boolean  @default(false)
  viewCount  Int      @default(0)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([visibility, updatedAt])
  @@index([viewCount])
}

/// A coding challenge with starter code + hidden tests.
/// Difficulty: "easy" | "medium" | "hard". Stored as string for SQLite portability.
model Challenge {
  id              String             @id @default(cuid())
  slug            String             @unique
  title           String
  /// Markdown description shown on the detail page.
  description     String
  /// "easy" | "medium" | "hard"
  difficulty      String             @default("easy")
  /// Sandpack template id (e.g. "test-ts", "react", "vanilla")
  template        String
  /// JSON map of starter files visible/editable to the user.
  starterFiles    String
  /// JSON map of hidden test files (run but not shown to user).
  testFiles       String
  /// JSON-encoded string[] of tag labels (e.g. "arrays", "react", "hooks").
  tags            String?
  /// Estimated time to solve, in minutes. Used for the timer default.
  estimatedMinutes Int               @default(15)
  /// Optional human-readable category (e.g. "Algorithms", "Frontend").
  category        String?
  /// Published challenges show up in the list. Drafts are owner-only.
  published       Boolean            @default(true)
  attempts        ChallengeAttempt[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([published, difficulty])
}

/// A user's attempt at a challenge.
/// status: "in_progress" | "passed" | "failed" | "abandoned"
model ChallengeAttempt {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  status      String    @default("in_progress")
  /// JSON map of the user's final submitted files (excluding hidden tests).
  files       String?
  /// JSON-encoded test results: { tests: [{name, status, error?}], passed, total }
  testResults String?
  /// Total elapsed seconds at submission.
  durationSec Int?
  /// Optional reference to the parent interview session.
  sessionId   String?
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?

  @@index([userId, status])
  @@index([challengeId])
  @@index([sessionId])
}

/// An interview session: a sequence of challenges with a hard time limit.
/// status: "scheduled" | "in_progress" | "completed" | "abandoned"
model InterviewSession {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String   @default("Interview Session")
  /// JSON-encoded string[] of challenge IDs, in order.
  challengeIds  String
  /// Hard time limit for the whole session, in seconds.
  totalSec      Int
  status        String   @default("scheduled")
  /// Random token used to grant read-only "interviewer view" access.
  shareToken    String   @unique
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([userId, status])
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?
  content     String   // Markdown content
  coverImage  String?
  published   Boolean  @default(false)
  viewCount   Int      @default(0)
  /// JSON-encoded string[] of tag labels (e.g. "react", "typescript", "ai").
  tags        String?
  /// Admin-only flag for staff-picked / featured posts.
  featured    Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions   BlogReaction[]
  comments    BlogComment[]
  bookmarks   BlogBookmark[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([published, createdAt])
  @@index([featured, createdAt])
}

/// A reaction to a blog post (clap, heart, etc.). Type lets us extend later
/// without another model. One row per (post, user, type).
model BlogReaction {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// "clap" for v1. Future: "heart", "fire", "unicorn".
  type      String   @default("clap")
  createdAt DateTime @default(now())

  @@unique([postId, userId, type])
  @@index([postId])
  @@index([userId])
}

/// A comment on a blog post. parentId enables threading — currently flat in UI.
model BlogComment {
  id        String        @id @default(cuid())
  postId    String
  post      BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    BlogComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   BlogComment[] @relation("CommentReplies")
  content   String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([postId, createdAt])
  @@index([userId])
}

/// Saved-for-later bookmarks. Composite PK avoids duplicate saves.
model BlogBookmark {
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([postId, userId])
  @@index([userId, createdAt])
}
