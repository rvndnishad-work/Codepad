generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection used at runtime by serverless functions.
  // On Vercel Postgres this is POSTGRES_PRISMA_URL.
  url       = env("DATABASE_URL")
  // Direct (non-pooling) connection used by `prisma migrate` / introspection.
  // On Vercel Postgres this is POSTGRES_URL_NON_POOLING.
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                @id @default(cuid())
  name                 String?
  email                String?               @unique
  emailVerified        DateTime?
  image                String?
  /// bcrypt hash for credentials login. null when only OAuth is used.
  passwordHash         String?
  /// Optional public profile bio shown on /u/[id] portfolio page.
  bio                  String?
  /// Optional "Hire Me" contact (email, URL, etc.) shown on portfolio.
  hireMeUrl            String?
  /// Whether the user wants their portfolio publicly visible.
  portfolioPublic      Boolean               @default(false)
  /// Whether the user is banned from the platform.
  banned               Boolean               @default(false)
  createdAt            DateTime              @default(now())
  /// User type — "candidate" (job seeker), "recruiter" (hiring), or null
  /// for legacy accounts that haven't been migrated to the new taxonomy.
  /// Drives navbar, dashboard, and interview-route experience.
  userType             String?
  companyName          String?
  companySize          String?
  jobTitle             String?

  /// TOTP secret (RFC 6238), encrypted at rest with the AES-GCM helper
  /// (`v1:iv:tag:ct` format, same as IP-2). Null when 2FA is not enrolled.
  totpSecret           String?
  /// Set when the user finishes the verify step. Until this is non-null the
  /// `totpSecret` is a "pending" enrollment that shouldn't gate logins —
  /// keeping the active-vs-pending distinction as one boolean check.
  totpEnabledAt        DateTime?
  /// JSON-encoded array of `{ hash: string, usedAt: string | null }`. Each
  /// `hash` is a SHA-256 hex digest of a one-time backup code. Storing
  /// hashes (not plaintext, not reversible-encrypted) means a DB leak still
  /// can't reveal the codes.
  totpBackupCodes      String?

  /// Per-user delta over the union of this user's GLOBAL roles. JSON object
  /// `{ "<permission>": boolean }` — true grants, false revokes. null = pure
  /// role union. Resolved by src/lib/permissions (resolveEffective).
  permissionOverrides  Json?

  accounts             Account[]
  roles                UserRole[]
  blogBookmarks        BlogBookmark[]
  blogComments         BlogComment[]
  blogs                BlogPost[]
  blogReactions        BlogReaction[]
  authoredChallenges   Challenge[]           @relation("AuthoredChallenges")
  attempts             ChallengeAttempt[]
  challengeEnrollments ChallengeEnrollment[]
  sentChallengeInvites ChallengeInvitation[] @relation("ChallengeInvitedBy")
  challengeInvitations ChallengeInvitation[] @relation("ChallengeInvitedUser")
  followers            Follow[]              @relation("following")
  following            Follow[]              @relation("follower")
  interviewSessions    InterviewSession[]
  sessions             Session[]
  snippets             Snippet[]
  workspaces           WorkspaceMember[]
  securityEvents       SecurityAuditLog[]
  notifications        Notification[]
  notificationPreferences NotificationPreference[]
  prepQuestionComments PrepQuestionComment[]
  savedPrepQuestions   PrepQuestion[]        @relation("UserSavedPrepQuestions")
  solvedPrepQuestions  PrepQuestion[]        @relation("UserSolvedPrepQuestions")
  prepJourneys         PrepJourney[]
  prepActivities       PrepActivity[]
}

/// Admin-composed broadcast (IP-45). One row per admin send; the per-recipient
/// fan-out rows live in Notification with broadcastId set. Recipient count is
/// denormalised so the sent log can render without a per-row aggregate.
model BroadcastNotification {
  id              String   @id @default(cuid())
  composedById    String
  /// Audience selector: "ALL" | "ALL_CANDIDATES" | "ALL_RECRUITERS"
  /// | "WORKSPACE" | "USER"
  audienceType    String
  /// Only set when audienceType is "WORKSPACE" or "USER" — the workspace id
  /// or user id the broadcast targets. Null for the broad audiences.
  audienceTarget  String?
  title           String
  body            String?
  href            String?
  recipientCount  Int      @default(0)
  /// Set when the broadcast finishes fanning out. Null while in progress.
  sentAt          DateTime?
  createdAt       DateTime @default(now())
  notifications   Notification[]

  @@index([composedById, createdAt])
}

/// In-app notification (IP-40). One row per delivered notification per user.
/// Cross-persona: candidates and recruiters both see the same shape; the
/// `type` field discriminates rendering. `payload` is event-specific JSON —
/// kept small (URLs + a couple of strings), not used to store anything
/// sensitive.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  /// Set when this row was fanned out from a BroadcastNotification (IP-45).
  /// Null for event-driven rows (IP-44). Lets the admin sent log group
  /// fanned-out rows + count read/dismiss rates.
  broadcastId String?
  broadcast BroadcastNotification? @relation(fields: [broadcastId], references: [id], onDelete: SetNull)
  /// Stable type discriminator. Current values (extensible):
  ///   INTERVIEW_SCHEDULED       — recruiter scheduled a session for this candidate
  ///   INTERVIEW_REPLAY_READY    — replay finished processing, ready to review
  ///   TAKE_HOME_EXPIRING        — < 24h remaining on a pending take-home
  ///   TAKE_HOME_SUBMITTED       — candidate submitted; recruiter view
  ///   SCORECARD_REQUESTED       — recruiter needs to finalize a scorecard
  ///   PROMPT_UPVOTED            — community upvoted your prompt attempt
  ///   AI_CREDITS_LOW            — workspace AI screening credits running low
  ///   SECURITY_2FA_ENABLED      — self-notification on TOTP enrollment success
  ///   SECURITY_2FA_DISABLED     — self-notification on TOTP disable
  type      String
  title     String
  body      String?
  /// Optional URL the row links to when clicked.
  href      String?
  /// Event-specific JSON for the renderer (e.g. candidate name, workspace
  /// slug, deltas). Stored as a string for SQLite portability.
  payload   String?
  /// Null while unread. Mutated on first click / "Mark all read".
  readAt    DateTime?
  /// Set when the user explicitly dismisses (X button). Row stays for audit
  /// but is hidden from the dropdown.
  dismissedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dismissedAt, createdAt])
  @@index([userId, readAt])
}

/// Per-user notification preferences (IP-47). One row per (userId, type)
/// pair; absence means "use default" so a fresh account doesn't need to
/// pre-populate every type.
///
/// Security types (SECURITY_2FA_*) and ADMIN_BROADCAST are forced ON in the
/// helper layer regardless of any preference row — these aren't user-suppressible.
model NotificationPreference {
  id            String   @id @default(cuid())
  userId        String
  type          String
  inAppEnabled  Boolean  @default(true)
  emailEnabled  Boolean  @default(true)
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

/// User-scoped security audit trail (IP-42). Separate from McpAuditLog so
/// MCP telemetry stays workspace-scoped and we have a clean per-user trail
/// for compliance asks. Reusable for future events: password changes, sign-
/// in from a new device, recovery-code use, etc.
model SecurityAuditLog {
  id        String   @id @default(cuid())
  userId    String
  /// Stable enum-ish string. Current values:
  ///   TOTP_ENROLL_START   — user clicked "Set up 2FA", secret minted but unverified
  ///   TOTP_ENROLL_VERIFY  — user successfully verified the first 6-digit code
  ///   TOTP_DISABLE        — user disabled 2FA
  ///   TOTP_VERIFY_FAILED  — bad code during enrollment verify (rate-limit signal)
  ///   TOTP_BACKUP_REGEN   — backup codes regenerated
  event     String
  /// Approximate client IP (best-effort, from request headers).
  ip        String?
  /// User-agent string for the request.
  userAgent String?
  /// Event-specific JSON. Kept small — never store secrets here.
  meta      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([event, createdAt])
}

/// Transactional email log (IP-25). One row per `sendEmail()` dispatch — the
/// row is written *before* the Resend POST (status="queued") and updated to
/// `sent` or `failed` immediately after. The Resend webhook (IP-25 AC #5)
/// flips it to `delivered` / `bounced` / `complained` / `opened` / `clicked`.
///
/// `providerId` is the Resend message id — webhook events join on it.
/// `template` is the registry key from src/emails/index.ts so we can roll up
/// per-template delivery stats.
model EmailLog {
  id             String    @id @default(cuid())
  template       String
  recipientEmail String
  /// Optional workspace context — set when the send was triggered by a
  /// workspace-scoped action (invite, notify, etc.).
  workspaceId    String?
  /// Optional interview / take-home / generic session id for traceability.
  sessionId      String?
  /// Resend message id, when the provider accepted the request. Null while
  /// queued and on failed sends.
  providerId     String?
  /// queued | sent | failed | delivered | bounced | complained | opened |
  /// clicked | suppressed. `suppressed` is the short-circuit case when the
  /// recipient is on the EmailSuppression list — we record the attempt
  /// without contacting Resend.
  status         String    @default("queued")
  /// Set when status flips to `failed` or `bounced`. Carries the Resend
  /// reason string truncated to a reasonable length.
  errorReason    String?
  createdAt      DateTime  @default(now())
  /// Updated each time a webhook event lands so the admin view can sort by
  /// most-recent activity.
  lastEventAt    DateTime?

  @@index([recipientEmail, createdAt])
  @@index([providerId])
  @@index([status, createdAt])
  @@index([workspaceId, createdAt])
}

/// Outbound deliverability suppression list (IP-25). Once an address hard-
/// bounces or files a complaint we never send to it again — Resend penalizes
/// senders that keep mailing known-bad addresses. Stored canonical (lowercase
/// trim) so lookups are exact-match.
model EmailSuppression {
  id        String   @id @default(cuid())
  address   String   @unique
  /// hard_bounce | complaint | unsubscribe | manual
  reason    String
  /// Optional human note (admin context).
  note      String?
  addedAt   DateTime @default(now())

  @@index([reason, addedAt])
}

/// Workspace-scoped audit trail (IP-37). Separate from McpAuditLog (which is
/// specialized for MCP telemetry — durationMs, errorCode, outboundUrl,
/// apiKey relation) and from SecurityAuditLog (which is user-scoped).
///
/// One row per workspace-mutating action. The `action` column is a stable
/// enum-ish string discriminator; `meta` carries event-specific JSON. We
/// store an actorUserId snapshot (rather than only relying on the FK) so
/// that user deletion still leaves a readable trail for compliance.
///
/// Coverage today (IP-37 MVP): pipeline stage transitions, bulk take-home
/// dispatch, ATS connect/disconnect. Remaining writers tracked in IP-76.
model WorkspaceAuditLog {
  id           String    @id @default(cuid())
  workspaceId  String
  actorUserId  String?
  /// Snapshot of actor email at write time — survives the actor's deletion
  /// for compliance readability ("rvndnishad@..." stays after the row goes).
  actorEmail   String?
  /// Stable discriminator. Current values:
  ///   PIPELINE_STAGE_CHANGED
  ///   BULK_TAKE_HOME_DISPATCHED
  ///   ATS_INTEGRATION_CONNECTED
  ///   ATS_INTEGRATION_DISCONNECTED
  ///   ATS_INTEGRATION_TEST_SENT
  ///   (extensible — IP-76 wires more)
  action       String
  /// Optional polymorphic reference. e.g. "candidate" + candidate.id, or
  /// "takeHomeAssignment" + assignment.id. Used by the UI to deep-link.
  targetType   String?
  targetId     String?
  /// Event-specific JSON. Kept small; never store secrets.
  meta         String?
  /// Best-effort client IP from request headers (`x-forwarded-for` etc).
  ip           String?
  /// User-agent string.
  userAgent    String?
  createdAt    DateTime  @default(now())
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, action, createdAt])
  @@index([workspaceId, actorUserId, createdAt])
}

model Follow {
  followerId  String
  followingId String
  following   User   @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  follower    User   @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Snippet {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String   @default("Untitled")
  template   String
  /// JSON map of { "/path": "contents" }
  files      String
  visibility String   @default("private")
  /// JSON-encoded string[] of tag labels
  tags       String?
  pinned     Boolean  @default(false)
  viewCount  Int      @default(0)
  userId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([visibility, updatedAt])
  @@index([viewCount])
}

/// A coding challenge with starter code + hidden tests.
/// Difficulty: "easy" | "medium" | "hard". Stored as string for SQLite portability.
model Challenge {
  id                  String                @id @default(cuid())
  slug                String                @unique
  title               String
  /// Markdown description shown on the detail page.
  description         String
  /// "easy" | "medium" | "hard"
  difficulty          String                @default("easy")
  /// Sandpack template id (e.g. "test-ts", "react", "vanilla")
  template            String
  /// JSON map of starter files visible/editable to the user.
  starterFiles        String
  /// JSON map of hidden test files (run but not shown to user).
  testFiles           String
  /// JSON-encoded string[] of tag labels (e.g. "arrays", "react", "hooks").
  tags                String?
  /// Estimated time to solve, in minutes. Used for the timer default.
  estimatedMinutes    Int                   @default(15)
  /// Optional human-readable category (e.g. "Algorithms", "Frontend").
  category            String?
  /// Published challenges show up in the list. Drafts are owner-only.
  published           Boolean               @default(true)
  /// "public" | "private". Only meaningful when published=true; mirrors the
  /// same field on ChallengeTrack (Track is being folded into Challenge in
  /// Stage 2 — keeping the names aligned so the migration is mechanical).
  visibility          String                @default("public")
  /// Staff-pick flag — surfaces a star badge on /challenges and bumps the
  /// challenge to the top of the grid. Admin-only.
  featured            Boolean               @default(false)
  /// Whether the challenge requires a premium/paid subscription to access.
  premium             Boolean               @default(false)
  /// Single null author = admin/curated; non-null = user-authored.
  authorId            String?
  workspaceId         String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  workspace           Workspace?            @relation(fields: [workspaceId], references: [id])
  author              User?                 @relation("AuthoredChallenges", fields: [authorId], references: [id])
  attempts            ChallengeAttempt[]
  enrollments         ChallengeEnrollment[]
  invitations         ChallengeInvitation[]
  steps               ChallengeStep[]
  takeHomeAssignments TakeHomeAssignment[]

  @@index([published, featured, difficulty])
  @@index([authorId])
}

/// One ordered step inside a Challenge. Stage 1 introduces this as the new
/// home for the runnable code/tests; the parent Challenge still carries the
/// legacy starterFiles/testFiles/template fields during the transition so
/// no read path breaks before Stage 2 cleans them up.
///
/// Single-step challenges: one ChallengeStep row mirroring the parent.
/// Multi-step challenges (Track replacements): N rows, position 0..N-1.
model ChallengeStep {
  id               String             @id @default(cuid())
  challengeId      String
  position         Int
  /// Optional per-step title — for multi-step challenges this is "Step 1:
  /// Two Sum". Single-step challenges just leave it null and reuse the
  /// parent Challenge title.
  title            String?
  /// Markdown description for this step. Overrides the parent's description
  /// when rendering the step's instructions.
  description      String
  /// Sandpack template id (e.g. "test-ts", "react", "vanilla").
  template         String
  /// JSON map of { "/path": "code" } — visible/editable to the user.
  starterFiles     String
  /// JSON map of { "/path": "code" } — hidden test files.
  testFiles        String
  estimatedMinutes Int                @default(15)
  /// Optional hint, surfaced behind a "Show hint" toggle on the attempt page.
  hint             String?
  /// Optional walkthrough video. YouTube / Vimeo / Loom auto-embed.
  videoUrl         String?
  /// JSON-encoded array of test cases: Array<{ id: string, name: string, input: string, expected: string, isHidden: boolean, weight: number }>
  testCasesJson    String             @default("[]")

  // ── Multi-language function-harness judging (server-side via Piston) ──
  /// "harness" = function-harness (multi-language, server-graded);
  /// "unit-js" = legacy in-browser Jest; "frontend" = manual-review UI challenge.
  judgingMode      String             @default("unit-js")
  /// Harness: the function the candidate implements.
  functionName     String?
  /// Harness: JSON `{ params: [{name,type}], returnType }` (see src/lib/judge/types.ts).
  signatureJson    String?
  /// Harness: JSON string[] of enabled language ids (e.g. ["python","go"]).
  languagesJson    String?
  /// Harness: JSON map `{ lang: "starter stub" }` (generated, author-editable).
  starterCodeJson  String?
  /// Harness: JSON map `{ lang: "reference solution" }`. AUTHOR-ONLY — never
  /// sent to candidates; used by Validate to generate expected outputs.
  referenceSolutionsJson String?
  /// Harness: JSON array of cases `[{ id, name, argsJson, expectedJson, isHidden, weight, compare }]`.
  /// `expectedJson` is filled by the admin Validate step.
  harnessTestsJson String             @default("[]")

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  attempts         ChallengeAttempt[]
  challenge        Challenge          @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, position])
  @@index([challengeId, position])
}

/// Stage 2 unified enrollment — replaces ChallengeTrackEnrollment once
/// Tracks are folded into Challenges. Same shape, same status state machine.
model ChallengeEnrollment {
  id            String    @id @default(cuid())
  userId        String
  challengeId   String
  /// "active" | "stashed" | "completed" | "abandoned"
  status        String    @default("active")
  startedAt     DateTime  @default(now())
  lastVisitedAt DateTime  @default(now())
  completedAt   DateTime?
  challenge     Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId, status])
  @@index([challengeId])
}

/// Stage 2 unified invitation — replaces TrackInvitation. Same magic-link
/// model: opaque token, email-keyed, status state machine.
/// status: "pending" | "accepted" | "revoked"
model ChallengeInvitation {
  id          String    @id @default(cuid())
  challengeId String
  email       String
  userId      String?
  token       String    @unique
  invitedById String?
  status      String    @default("pending")
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  invitedBy   User?     @relation("ChallengeInvitedBy", fields: [invitedById], references: [id])
  user        User?     @relation("ChallengeInvitedUser", fields: [userId], references: [id])
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, email])
  @@index([email])
  @@index([userId])
  @@index([challengeId, status])
}

/// A user's relationship to a track. One row per (user, track); state machine
/// driven by user actions. Track progress is computed from ChallengeAttempt
/// rows — we don't denormalise the "solved count" to avoid drift.
/// status: "active" | "stashed" | "completed" | "abandoned"
/// A user's attempt at a challenge.
/// status: "in_progress" | "passed" | "failed" | "abandoned"
model ChallengeAttempt {
  id                 String                    @id @default(cuid())
  userId             String
  challengeId        String
  /// Which step inside the challenge this attempt is for. Nullable for
  /// pre-migration rows; populated by the Stage 1 backfill script. New
  /// attempts MUST set this.
  stepId             String?
  status             String                    @default("in_progress")
  /// JSON map of the user's final submitted files (excluding hidden tests).
  files              String?
  /// JSON-encoded test results: { tests: [{name, status, error?}], passed, total }
  testResults        String?
  /// Total elapsed seconds at submission.
  durationSec        Int?
  /// Optional reference to the parent interview session.
  sessionId          String?
  startedAt          DateTime                  @default(now())
  finishedAt         DateTime?
  /// Calculated overall score (e.g. 85 out of 100)
  score              Int?
  aiSuspicionScore   Float?
  integrityReport    CandidateIntegrityReport?
  step               ChallengeStep?            @relation(fields: [stepId], references: [id])
  challenge          Challenge                 @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventLog           SessionEventLog?
  takeHomeAssignment TakeHomeAssignment?

  @@index([userId, status])
  @@index([challengeId])
  @@index([sessionId])
}

/// An interview session: a sequence of challenges with a hard time limit.
/// status: "scheduled" | "in_progress" | "completed" | "abandoned"
model InterviewSession {
  id                 String           @id @default(cuid())
  userId             String
  title              String           @default("Interview Session")
  candidateName      String?
  type               String           @default("mock")
  verdict            String?
  notes              String?
  creatorRole        String           @default("candidate")
  /// Set when a guest candidate requests the interviewer to start the session.
  startRequestedAt   DateTime?
  /// What kind of starter material drives this session.
  /// "challenge" — DSA/algorithm-style round backed by Challenge.testFiles.
  /// "playground" — open framework/scenario round backed by Snippet.files,
  /// judged manually by the interviewer (no automated tests).
  sourceType         String           @default("challenge")
  /// JSON-encoded string[] of challenge IDs, in order.
  /// Used when sourceType = "challenge". May be "[]" otherwise.
  challengeIds       String
  /// Tracks the ID of the challenge currently being worked on.
  activeChallengeId  String?
  /// JSON-encoded string[] of Snippet IDs (playgrounds), in order.
  /// Used when sourceType = "playground". May be "[]" otherwise.
  playgroundIds      String           @default("[]")
  /// JSON-encoded string[] of PromptScenario IDs, in order.
  /// Used when sourceType = "prompt". May be "[]" otherwise.
  promptScenarioIds  String           @default("[]")
  /// Tracks the ID of the playground currently being worked on.
  activePlaygroundId String?
  /// Free-text scenario / prompt shown to the candidate during
  /// playground rounds (e.g. "Add pagination to this list component").
  /// Editable by the interviewer live; saved with the session.
  scenario           String?
  /// Hard time limit for the whole session, in seconds.
  totalSec           Int
  status             String           @default("scheduled")
  /// Random token used to grant read-only "interviewer view" access.
  shareToken         String           @unique
  /// A friendly 4-digit access code (e.g., "4921")
  shortCode          String?          @unique
  /// Planned meeting time picked at creation (IP-90). Distinct from
  /// startedAt/finishedAt, which record when the session actually ran —
  /// never overload those with scheduling data.
  scheduledAt        DateTime?
  startedAt          DateTime?
  finishedAt         DateTime?
  workspaceId        String?
  /// Optional link to first-class Candidate entity (V2). When set, the
  /// candidateName field above acts as a denormalized snapshot.
  candidateId        String?
  aiSuspicionScore   Float?
  /// ── Async take-home mode (IP-88) ───────────────────────────────────────
  /// When `type = "take-home"` this session is an async, candidate-self-serve
  /// assessment rather than a live interview. The fields below only apply in
  /// that mode; live/mock sessions leave them null.
  ///
  /// Tokenless candidate "do-the-assessment" link, distinct from `shareToken`
  /// (which grants the interviewer read-only view).
  candidateAccessToken  String?       @unique
  /// Last moment the candidate may START the take-home (the invite expiry).
  deadlineAt            DateTime?
  /// Idempotency flag for the 24h reminder cron (mirrors TakeHomeAssignment).
  reminderSentAt        DateTime?
  /// Per-question time limits, JSON map { [sourceId]: minutes }. Drives the
  /// per-question countdown in the async runner.
  questionTimeLimitsJson String?
  /// Chosen tech stack for prep sessions built via the Tech-Stack selector.
  /// JSON of `TechStack` (see src/lib/interview/stack.ts). Null for sessions
  /// assembled manually. Used for context/labels + AI question steering.
  stackJson          String?
  /// ── Native proctor agent (overlay/AI-tool detection) ──────────────────────
  /// One-time bearer token the desktop agent presents on every report. Issued
  /// per session; rotating/clearing it revokes the agent (it self-uninstalls).
  proctorToken       String?          @unique
  /// Per-session secret used to HMAC-sign agent report bodies. Never sent to
  /// the browser; only embedded in the agent launcher env.
  proctorSecret      String?
  createdAt          DateTime         @default(now())
  rubric             InterviewRubric?
  proctorReport      ProctorAgentReport?
  candidate          Candidate?       @relation(fields: [candidateId], references: [id])
  workspace          Workspace?       @relation(fields: [workspaceId], references: [id])
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([candidateId])
  @@index([workspaceId])
  /// Listing take-home sessions per workspace (IP-88).
  @@index([workspaceId, type])
}

model BlogPost {
  id         String         @id @default(cuid())
  slug       String         @unique
  title      String
  excerpt    String?
  content    String
  coverImage String?
  published  Boolean        @default(false)
  viewCount  Int            @default(0)
  /// JSON-encoded string[] of tag labels (e.g. "react", "typescript", "ai").
  tags       String?
  /// "DRAFT" | "PENDING" | "PUBLISHED" | "REJECTED" | "NEEDS_CHANGES"
  status     String         @default("DRAFT")
  /// Feedback from admin if changes are needed or rejection reason.
  adminNotes String?
  /// Admin-only flag for staff-picked / featured posts.
  featured   Boolean        @default(false)
  userId     String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  bookmarks  BlogBookmark[]
  comments   BlogComment[]
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions  BlogReaction[]

  @@index([userId])
  @@index([published, createdAt])
  @@index([featured, createdAt])
}

/// A reaction to a blog post (clap, heart, etc.). Type lets us extend later
/// without another model. One row per (post, user, type).
model BlogReaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  /// "clap" for v1. Future: "heart", "fire", "unicorn".
  type      String   @default("clap")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
  @@index([postId])
  @@index([userId])
}

/// A comment on a blog post. parentId enables threading — currently flat in UI.
model BlogComment {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  parentId  String?
  content   String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  parent    BlogComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   BlogComment[] @relation("CommentReplies")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId])
}

/// Saved-for-later bookmarks. Composite PK avoids duplicate saves.
model BlogBookmark {
  postId    String
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId, createdAt])
}

model SiteSetting {
  key   String @id
  value String
}

model TakeHomeAssignment {
  id             String            @id @default(cuid())
  challengeId    String
  candidateName  String
  candidateEmail String
  token          String            @unique
  status         String            @default("PENDING")
  expiresAt      DateTime
  timeLimitMin   Int               @default(60)
  startedAt      DateTime?
  submittedAt    DateTime?
  /// Set when the 24h reminder email fired (IP-27). Guards the reminder cron
  /// against double-sending on re-runs.
  reminderSentAt DateTime?
  attemptId      String?           @unique
  workspaceId    String?
  /// Optional link to the first-class Candidate entity. Backfilled by the
  /// candidate seed/migration; candidateName/email above are retained as a
  /// denormalized snapshot for back-compat and for guest invites.
  candidateId    String?
  createdAt      DateTime          @default(now())
  candidate      Candidate?        @relation(fields: [candidateId], references: [id])
  workspace      Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  attempt        ChallengeAttempt? @relation(fields: [attemptId], references: [id])
  challenge      Challenge         @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([candidateEmail])
  @@index([candidateId])
  @@index([workspaceId])
}

model Workspace {
  id                   String                    @id @default(cuid())
  name                 String
  slug                 String                    @unique
  stripeCustomerId     String?                   @unique
  stripeSubscriptionId String?                   @unique
  planName             String                    @default("FREE")
  /// Phase 4.1 workspace-level kill-switch for outbound external MCP calls
  /// during AI screenings. Even if individual templates have ExternalMcpServer
  /// bindings, the wire is dead unless this flag is true. Defaults false so
  /// nothing leaks while admins are still figuring out their setup.
  allowExternalMcp     Boolean                   @default(false)
  /// IP-91: 14-day free trial window. Set at creation; null once the trial has
  /// been consumed/cleared. `effectivePlan()` treats an unexpired trial as
  /// GROWTH-level access regardless of planName.
  trialEndsAt          DateTime?
  createdAt            DateTime                  @default(now())
  aiCreditLedger       AIInterviewCreditLedger[]
  aiInterviewSessions  AIInterviewSession[]
  aiInterviewTemplates AIInterviewTemplate[]
  aiScreeningBatches   AIScreeningBatch[]
  atsIntegration       AtsIntegration?
  candidates           Candidate[]
  challenges           Challenge[]
  sessions             InterviewSession[]
  mcpApiKeys           McpApiKey[]
  mcpAuditLogs         McpAuditLog[]
  externalMcpServers   ExternalMcpServer[]
  promptScenarios      PromptScenario[]
  takeHomes            TakeHomeAssignment[]
  members              WorkspaceMember[]
  invites              WorkspaceInvite[]
  auditLogs            WorkspaceAuditLog[]
}

/// Pending teammate invitation (IP-73). Replaces the old "silently mint a
/// placeholder User" flow: an invite is created + emailed, and a
/// WorkspaceMember row is only created when the invitee accepts (on auth).
model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  /// Role to grant on acceptance (never OWNER — ownership transfers via PATCH).
  role        String    @default("INTERVIEWER")
  /// One-time acceptance token used in the /invite/[token] URL.
  token       String    @unique @default(cuid())
  invitedById String?
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([workspaceId])
}

/// First-class candidate entity scoped to a workspace.
/// Replaces the previous "implicit candidate" pattern where candidate info
/// only lived inline on TakeHomeAssignment / InterviewSession rows.
/// status: "active" | "hired" | "rejected" | "archived"
model Candidate {
  id                  String               @id @default(cuid())
  workspaceId         String
  name                String
  email               String?
  phone               String?
  /// Where this candidate came from (e.g. "linkedin", "referral", "ats", "manual").
  source              String?
  /// Free-text notes — the recruiter's running journal on the candidate.
  notes               String?
  /// JSON-encoded string[] of tags (e.g. ["senior", "react", "remote-ok"]).
  tags                String?
  /// Disposition flag — semantically "what's the current bucket for this
  /// person?" Historical values: active/future_hire/do_not_hire/hired/
  /// rejected/archived. Coexists with `stage` (the pipeline position) — see
  /// IP-34. Kept for backwards compat with existing queries.
  status              String               @default("active")
  /// IP-34: pipeline stage. One of:
  ///   APPLIED → SCREENED → TAKE_HOME → ONSITE → OFFER → HIRED
  ///                                                       ↘ REJECTED
  /// REJECTED requires `rejectReason` set. Drag-drop on the Kanban moves
  /// candidates between these.
  stage               String               @default("APPLIED")
  /// IP-34: when set, why this candidate was rejected.
  ///   SKILL_GAP / CULTURE_FIT / COMP_MISMATCH / NO_RESPONSE / WITHDREW / OTHER
  rejectReason        String?
  /// Free-text expansion on rejectReason (e.g. "Salary expectation 30% over band").
  rejectReasonNote    String?
  /// Last time `stage` mutated — drives "time-in-stage" diagnostics.
  stageChangedAt      DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  aiInterviewSessions AIInterviewSession[]
  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sessions            InterviewSession[]
  takeHomes           TakeHomeAssignment[]

  @@unique([workspaceId, email])
  @@index([workspaceId, status])
  @@index([workspaceId, name])
  @@index([workspaceId, stage])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  /// References Role.key for a WORKSPACE-scoped role (OWNER/ADMIN/RECRUITER/
  /// INTERVIEWER/VIEWER). Kept as a plain string (not an FK) so existing rows
  /// stay valid and the seeded role keys are the contract.
  role        String    @default("INTERVIEWER")
  /// Per-member delta over the role's base permissions. JSON object
  /// `{ "<permission>": boolean }` — true grants, false revokes. null = pure
  /// role defaults. Resolved by src/lib/permissions (resolveEffective).
  permissions Json?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

/// DB-defined role: a named bundle of code-defined permissions. Roles can be
/// created/recomposed at runtime (admin role editor) without a deploy; the
/// permissions they reference must exist in src/lib/permissions (validated at
/// write time via isPermission). `scope` partitions GLOBAL roles (held via
/// UserRole) from WORKSPACE roles (referenced by WorkspaceMember.role.key).
model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  label       String
  /// "GLOBAL" | "WORKSPACE"
  scope       String
  description String?
  /// Seeded system roles — protected from deletion in the role editor.
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  permissions RolePermission[]
  userRoles   UserRole[]

  @@index([scope])
}

/// One permission string granted to a Role. The string is a member of the
/// Permission union in src/lib/permissions/permissions.ts (or a "*" /
/// "resource:*" wildcard), validated before insert.
model RolePermission {
  id         String @id @default(cuid())
  roleId     String
  permission String
  role       Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
}

/// Assignment of a GLOBAL Role to a User (many-to-many — a user may hold
/// several roles, e.g. CREATOR + MODERATOR). Workspace roles are NOT assigned
/// here; they live on WorkspaceMember.role.
model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
}

model SessionEventLog {
  id         String           @id @default(cuid())
  attemptId  String           @unique
  eventsData String
  createdAt  DateTime         @default(now())
  attempt    ChallengeAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
}

model CandidateIntegrityReport {
  id             String           @id @default(cuid())
  attemptId      String           @unique
  suspicionScore Int              @default(0)
  totalBlurSec   Int              @default(0)
  blurCount      Int              @default(0)
  pasteCount     Int              @default(0)
  pasteDetails   String
  createdAt      DateTime         @default(now())
  attempt        ChallengeAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
}

model InterviewRubric {
  id            String           @id @default(cuid())
  sessionId     String           @unique
  ratings       String
  notes         String?
  interviewerId String
  createdAt     DateTime         @default(now())
  session       InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

/// Latest state reported by the native proctor agent for one interview session.
/// Unlike CandidateIntegrityReport (browser telemetry, keyed to ChallengeAttempt)
/// this captures OS-level overlay / capture-excluded-window detections the
/// browser cannot see. One row per session, upserted on each agent report.
model ProctorAgentReport {
  id             String           @id @default(cuid())
  sessionId      String           @unique
  /// Highest report sequence number accepted so far (replay/gap detection).
  lastSeq        Int              @default(0)
  /// Latest native suspicion score from the agent (0..=100).
  suspicionScore Int              @default(0)
  /// Highest suspicion seen across the whole session.
  peakSuspicion  Int              @default(0)
  scannedWindows Int              @default(0)
  /// JSON-encoded array of the latest scan's DetectionSignal objects.
  signalsData    String           @default("[]")
  reportCount    Int              @default(0)
  agentVersion   String?
  agentConnected Boolean          @default(true)
  firstSeenAt    DateTime         @default(now())
  lastSeenAt     DateTime         @default(now())
  session        InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model AtsIntegration {
  id            String    @id @default(cuid())
  workspaceId   String    @unique
  provider      String
  apiKey        String
  webhookSecret String?
  settings      String    @default("{}")
  createdAt     DateTime  @default(now())
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AIInterviewSession {
  id               String                    @id @default(cuid())
  workspaceId      String
  candidateId      String?
  /// Revamp: the screening batch this session belongs to. Null for legacy
  /// single-template sessions created before the batch model (treated as an
  /// implicit 1-round screening via the templateId below).
  batchId          String?
  /// One-time token used in candidate-facing URL. Distinct from the session id
  /// so admin/internal ids are never leaked.
  inviteToken      String                    @unique @default(cuid())
  candidateName    String
  candidateEmail   String
  positionTitle    String
  status           String                    @default("PENDING")
  /// Candidate self-serve practice run (no recruiter, no credit charge). Hosted
  /// under the reserved practice workspace; credit consumption is skipped.
  practice         Boolean                   @default(false)
  chatHistory      String
  filesJson        String
  templateId       String
  score            Int?
  ratings          String?
  aiSummary        String?
  /// Proctoring signal — 0..1, populated when integrity events are captured.
  aiSuspicionScore Float?
  /// Set atomically when the candidate sends their first message. Acts as the
  /// "credit consumed" sentinel — `updateMany WHERE startedAt IS NULL` guards
  /// against double-charge from concurrent first POSTs.
  startedAt        DateTime?
  finishedAt       DateTime?
  /// Phase 4.1 outbound MCP budget counters. Each external-MCP call by the
  /// AI interviewer bumps these; if any exceeds the per-session cap, Gemini
  /// gets a tool error (not the screening — that continues).
  outboundCallCount      Int     @default(0)
  outboundResponseBytes  Int     @default(0)
  outboundElapsedMs      Int     @default(0)
  /// JSON snapshot of available external tools at session start. Cached so
  /// every turn doesn't re-fetch tools/list from the customer's MCP server.
  /// Shape: `{ servers: [{ id, label, tools: [...] }], cachedAt }`.
  outboundToolsListCache String?
  /// Live presence of the AI interviewer: "REACTIVE" (replies only when the
  /// candidate messages — default/legacy), "OBSERVER" (sparing proactive
  /// nudges) or "COACH" (actively present). Copied from the batch at invite so
  /// runtime + credit charge read it without a join. Drives credit cost.
  engagementLevel  String                    @default("REACTIVE")
  /// Count of proactive (observer/coach) comments emitted this session. Used to
  /// enforce the per-session hard cap on background AI interjections.
  proactiveCount   Int                       @default(0)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  ledgerEntries    AIInterviewCreditLedger[]
  candidate        Candidate?                @relation(fields: [candidateId], references: [id])
  workspace        Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  batch            AIScreeningBatch?         @relation(fields: [batchId], references: [id], onDelete: SetNull)
  rounds           AIInterviewRound[]

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([candidateId])
  @@index([batchId])
}

/// Revamp (2026-06): a screening campaign grouping multiple candidates under
/// one position with a SHARED question set (AIScreeningRoundSpec rows). Each
/// candidate gets one AIInterviewSession whose AIInterviewRound rows are
/// materialized from the shared specs (+ per-candidate overrides) at invite.
model AIScreeningBatch {
  id              String   @id @default(cuid())
  workspaceId     String
  positionTitle   String
  /// User id of the recruiter who created the batch.
  createdByUserId String
  /// "DRAFT" (being built, not yet invited) | "ACTIVE" | "CLOSED".
  status          String   @default("ACTIVE")
  /// Live presence the recruiter chose for this screening: "REACTIVE" |
  /// "OBSERVER" | "COACH". Copied onto each session at invite; sets credit cost.
  engagementLevel String   @default("REACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  workspace       Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  roundSpecs      AIScreeningRoundSpec[]
  sessions        AIInterviewSession[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, status])
}

/// The shared question-set blueprint for a batch. Each row is one round every
/// candidate gets by default. "Fullstack" is expressed as multiple specs
/// (e.g. a frontend spec + a backend spec), not a single paradigm value.
model AIScreeningRoundSpec {
  id               String  @id @default(cuid())
  batchId          String
  /// 0-based round order within the batch.
  order            Int
  /// "frontend" | "backend" | "dsa".
  paradigm         String
  /// Execution language for backend/dsa (e.g. "node", "python"). Null for frontend.
  language         String?
  /// Frontend framework id (react/vue/...) OR non-executable backend framework
  /// label. Steers surface choice + AI questioning.
  frameworkLabel   String?
  /// Problem origin: "challenge" | "playground" | "scaffold" (hybrid model).
  sourceKind       String
  /// Challenge id or playground/template id when sourceKind is challenge/playground.
  sourceId         String?
  /// AIInterviewTemplate id when sourceKind is "scaffold" (per-round override).
  templateId       String?
  estimatedMinutes Int     @default(30)
  batch            AIScreeningBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, order])
}

/// A single materialized round for ONE candidate's session. Cloned from a
/// batch's AIScreeningRoundSpec at invite, then individually overridable. Each
/// round owns its files + score + status. The conversation is shared at the
/// session level (one continuous chat with round-boundary markers — the locked
/// revamp default), so `chatHistory` here is reserved/nullable for a future
/// per-round-reset option. Credit is still charged once per SESSION (on the
/// first message of the first round), not per round.
model AIInterviewRound {
  id               String  @id @default(cuid())
  sessionId        String
  order            Int
  paradigm         String
  language         String?
  frameworkLabel   String?
  sourceKind       String
  sourceId         String?
  templateId       String?
  estimatedMinutes Int     @default(30)
  /// Per-round candidate file state (path -> code, JSON). Seeds from the
  /// resolved starter files for this round's source.
  filesJson        String    @default("{}")
  /// Reserved for a future per-round chat-reset mode. Null = shared session chat.
  chatHistory      String?
  /// Per-round score 0..100 + rubric, set at grade time. Session composite
  /// score aggregates these.
  score            Int?
  ratings          String?
  /// "PENDING" | "ACTIVE" | "COMPLETED".
  status           String  @default("PENDING")
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  session          AIInterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, order])
}

/// Workspace-scoped custom screening templates. The default `scaffolds.ts`
/// catalog still ships as builtins; rows here layer on top and are merged at
/// resolve time. NULL workspaceId is reserved for any future "global custom"
/// templates an admin might seed.
model AIInterviewTemplate {
  id               String     @id @default(cuid())
  workspaceId      String?
  title            String
  description      String
  starterFiles     String
  testsCode        String
  estimatedMinutes Int        @default(30)
  /// Coding-surface kind: "frontend" (Sandpack) | "backend" | "dsa" (Monaco +
  /// Piston console). Null defaults to frontend.
  kind             String?
  /// Execution language for backend/dsa surfaces (e.g. "node", "python").
  language         String?
  /// Non-executable framework label (steers AI questions only).
  frameworkLabel   String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  workspace        Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  externalMcpBindings TemplateExternalMcp[]

  @@index([workspaceId])
}

/// Append-only ledger of credit movements for a workspace. Balance is computed
/// as SUM(amount). `amount` is signed: positive for PURCHASE/GRANT/REFUND,
/// negative for CONSUMPTION.
model AIInterviewCreditLedger {
  id             String              @id @default(cuid())
  workspaceId    String
  kind           String
  amount         Int
  sessionId      String?
  stripeChargeId String?
  adminUserId    String?
  note           String?
  createdAt      DateTime            @default(now())
  session        AIInterviewSession? @relation(fields: [sessionId], references: [id])
  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([sessionId])
}

/// Workspace-scoped MCP API key. The full secret is shown ONCE at creation
/// and only the SHA-256 hash is persisted. `keyPreview` is the first few
/// characters of the plaintext, kept for UI display ("ip_live_a1b2…") so
/// recruiters can identify which key to revoke without ever seeing the
/// secret again.
model McpApiKey {
  id              String        @id @default(cuid())
  workspaceId     String
  label           String
  keyHash         String        @unique
  keyPreview      String
  /// JSON-encoded string[] of scopes, e.g. `["read"]` or `["read","write"]`.
  /// Phase 1 ships read-only; write tools arrive in Phase 2 and gate on this.
  scopes          String        @default("[\"read\"]")
  createdByUserId String?
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime      @default(now())
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  auditLogs       McpAuditLog[]

  @@index([workspaceId, revokedAt])
}

/// Append-only log of every MCP tool/resource invocation. Lets recruiters
/// (and admins) audit which keys touched what data. Args are stored as
/// truncated JSON because some tool params could be large.
model McpAuditLog {
  id            String     @id @default(cuid())
  workspaceId   String
  apiKeyId      String?
  /// "tool" | "resource" (inbound, from a customer's API key) or "outbound"
  /// (the AI interviewer calling into a customer-configured external MCP).
  kind          String
  name          String
  argsJson      String?
  resultSummary String?
  errorCode     String?
  durationMs    Int        @default(0)
  /// Populated for kind="outbound" — the remote MCP URL the call hit.
  outboundUrl   String?
  createdAt     DateTime   @default(now())
  apiKey        McpApiKey? @relation(fields: [apiKeyId], references: [id])
  workspace     Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([apiKeyId, createdAt])
}

/// A prompt engineering challenge scenario.
model PromptScenario {
  id               String           @id @default(cuid())
  slug             String           @unique
  title            String
  description      String
  objective        String
  expectedTraits   String
  difficulty       String           @default("intermediate")
  category         String           @default("code-generation")
  estimatedMinutes Int              @default(10)
  workspaceId      String?
  rubricWeights    String           @default("{\"clarity\":20,\"specificity\":20,\"efficiency\":15,\"context\":15,\"constraints\":15,\"edgeCases\":15}")
  published        Boolean          @default(true)
  /// Who authored this scenario. Null for built-in/seeded scenarios (only
  /// admins may edit those). Platform-wide scenarios created by ordinary users
  /// start unpublished and are editable/deletable by their author.
  authorId         String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  attempts         PromptAttempt[]
  exemplars        PromptExemplar[]
  workspace        Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, published])
  @@index([difficulty, category])
  @@index([authorId])
}

/// A candidate's submitted prompt for a scenario.
///
/// When `shared = true`, this attempt is also visible in the Community Prompts
/// tab for its scenario. `shareUpvotes` is the denormalised upvote count used
/// for sort order; the authoritative records live in PromptUpvote.
model PromptAttempt {
  id            String         @id @default(cuid())
  scenarioId    String
  promptText    String
  charCount     Int
  tokenEstimate Int
  score         Int?
  rubricScores  String?
  feedback      String?
  graderType    String?
  sessionId     String?
  userId        String?
  durationSec   Int?
  shared        Boolean        @default(false)
  shareTitle    String?
  shareNote     String?
  shareUpvotes  Int            @default(0)
  createdAt     DateTime       @default(now())
  scenario      PromptScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  upvotes       PromptUpvote[]

  @@index([scenarioId])
  @@index([sessionId])
  @@index([userId])
  @@index([scenarioId, shared, shareUpvotes])
}

/// Admin-curated example prompts attached to a scenario. Shown in the
/// "Exemplar Prompts" section of the Practice runner so developers can study
/// well-scoring approaches before writing their own. `source` is "admin" by
/// default; a future tool may promote high-upvote community shares to exemplars.
model PromptExemplar {
  id           String         @id @default(cuid())
  scenarioId   String
  title        String
  promptText   String
  summary      String
  rubricScores String?
  source       String         @default("admin")
  authorId     String?
  createdAt    DateTime       @default(now())
  scenario     PromptScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
}

/// One row per (attempt, user) upvote. Unique constraint enforces a single
/// vote per user per shared attempt. PromptAttempt.shareUpvotes mirrors the
/// count so the community list can sort without joining.
model PromptUpvote {
  id        String        @id @default(cuid())
  attemptId String
  userId    String
  createdAt DateTime      @default(now())
  attempt   PromptAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, userId])
  @@index([attemptId])
}

/// "Review the AI's code" challenge — a plausible AI-generated answer to a
/// stated prompt, with deliberately planted flaws (hallucinated APIs, subtle
/// logic bugs, security holes) the candidate must find. Grading is a
/// deterministic checklist of the planted ReviewFindings — no LLM calls.
model ReviewChallenge {
  id               String          @id @default(cuid())
  slug             String          @unique
  title            String
  /// The prompt the fictional AI assistant was answering. Shown as context so
  /// reviewers judge the code against its stated intent.
  prompt           String
  /// "javascript" | "typescript" | "python" | "sql" — must map to a
  /// highlight.js language registered in src/lib/code-peek.ts.
  language         String
  difficulty       String          @default("intermediate")
  /// Full code listing shown to the reviewer. Finding anchors are 1-based line
  /// numbers into this exact string — never reformat without re-anchoring.
  code             String
  estimatedMinutes Int             @default(10)
  /// Countdown for the timed "Hallucination Hunt" mode, in seconds.
  timeLimitSec     Int             @default(120)
  published        Boolean         @default(true)
  sortOrder        Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  findings         ReviewFinding[]
  attempts         ReviewAttempt[]

  @@index([published, sortOrder])
  @@index([language, difficulty])
}

/// One planted flaw in a ReviewChallenge. `lineStart..lineEnd` (1-based,
/// inclusive) anchors it in the challenge code; grading accepts a mark within
/// ±1 line of the range. Findings are only sent to the client after an attempt
/// is submitted (the reveal), never with the challenge itself.
model ReviewFinding {
  id          String          @id @default(cuid())
  challengeId String
  lineStart   Int
  lineEnd     Int
  /// "hallucinated-api" | "logic-bug" | "security" | "performance" | "edge-case"
  category    String
  title       String
  /// Reveal text: why the code is wrong and what the correct version looks like.
  explanation String
  points      Int             @default(10)
  challenge   ReviewChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([challengeId])
}

/// A reviewer's graded submission. `marks` is the JSON array of what they
/// flagged ([{ "line": 12, "category": "security" }]); the score breakdown is
/// recomputed deterministically server-side from the planted findings.
/// Like PromptAttempt, `userId` is a bare string (no FK) — anonymous attempts
/// are graded but not persisted.
model ReviewAttempt {
  id             String          @id @default(cuid())
  challengeId    String
  userId         String?
  marks          String
  /// 0–100 normalized score (finding points earned minus false-positive penalty).
  score          Int
  /// Findings hit with the correct category.
  foundCount     Int
  /// Findings hit on the right lines but with the wrong category (half credit).
  partialCount   Int
  totalFindings  Int
  falsePositives Int
  durationSec    Int?
  /// "standard" | "hunt" — hunt attempts are timed and feed the leaderboard.
  mode           String          @default("standard")
  createdAt      DateTime        @default(now())
  challenge      ReviewChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([challengeId])
  @@index([userId])
  @@index([mode, score])
}

/// Workspace-configured outbound MCP server. Used by the AI interviewer
/// (Phase 4.1) to call into customer-specific context during a screening —
/// internal docs, ATS, repo summaries, etc.
///
/// `authToken` is encrypted at rest (AES-256-GCM via src/lib/crypto/at-rest.ts).
/// Never returned to the UI after creation; the page passes only
/// `hasAuthToken: boolean` to the client.
///
/// `enabled` defaults to false so misconfigured servers can't accidentally
/// start being called. Wiring also requires per-template binding (TemplateExternalMcp)
/// AND the workspace-level `allowExternalMcp` kill-switch — three gates.
model ExternalMcpServer {
  id               String    @id @default(cuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name             String    // human-readable label
  url              String    // remote MCP endpoint URL
  authToken        String?   // bearer token (encrypted at rest). NEVER returned via API.
  enabled          Boolean   @default(false)
  lastTestedAt     DateTime?
  lastTestStatus   String?   // "ok" | "error" | null
  lastTestSummary  String?   // short result text — tool count or error message
  createdByUserId  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  templateBindings TemplateExternalMcp[]

  @@index([workspaceId])
}

/// Per-template binding for external MCP servers. The AI interviewer only
/// surfaces a server's tools to Gemini if (a) the server is enabled, (b)
/// it's bound here to the screening's template, and (c) the workspace has
/// `allowExternalMcp = true`. Three gates, all must be true.
model TemplateExternalMcp {
  id                  String    @id @default(cuid())
  templateId          String
  externalMcpServerId String
  createdAt           DateTime  @default(now())
  template            AIInterviewTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  server              ExternalMcpServer   @relation(fields: [externalMcpServerId], references: [id], onDelete: Cascade)

  @@unique([templateId, externalMcpServerId])
  @@index([templateId])
  @@index([externalMcpServerId])
}

/// Admin-only running scratchpad for the Interviewpad platform itself.
/// Internal to the platform team; not shown to recruiters/candidates.
/// `status` is a string for SQLite portability: BACKLOG | TODO | IN_PROGRESS | DONE.
/// `priority` is a string for the same reason: LOW | MEDIUM | HIGH.
/// `category` is free text so admins can group items however makes sense
/// at the moment ("MCP", "AI Screening", "Marketing", "Bug fix", etc.).
model AdminTodo {
  id           String    @id @default(cuid())
  /// Stable, human-readable ticket key like "IP-7" — the project-style identifier
  /// admins can drop into commit messages or chat. Format: `IP-<ticketSeq>`.
  /// Generated once at create time and never changes. Unique across the project.
  ticketKey    String?   @unique
  /// Monotonically increasing sequence number used to mint ticketKey. Stored
  /// separately so future renaming/re-prefixing doesn't have to re-derive.
  ticketSeq    Int?      @unique
  title        String
  body         String?
  /// JSON-encoded array of `{ text: string, done: boolean }`. Stored as a
  /// string for SQLite portability; the UI ticks checkboxes interactively.
  acceptanceCriteria String?
  /// Free-form scratchpad for the dev/product owner picking up the ticket —
  /// edge cases noticed mid-spec, links, who to ask, design tradeoffs, etc.
  ownerNotes   String?
  status       String    @default("BACKLOG")
  priority     String    @default("MEDIUM")
  category     String?
  /// Optional notes from the admin who added it — useful when someone else picks it up later.
  addedByEmail String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?

  outgoingDeps AdminTodoDependency[] @relation("DepFrom")
  incomingDeps AdminTodoDependency[] @relation("DepTo")

  @@index([status, priority])
}

/// Jira-style ticket-to-ticket links so deferred follow-ups, blockers, and
/// spawn relationships are queryable instead of buried in ownerNotes.
///
/// Directed edge: `(from, to, type)` reads "from {type} to":
///   BLOCKS         — from must complete before to starts
///   FOLLOWS_FROM   — from was spawned/deferred from to (parent → child trail)
///   RELATES_TO     — informational, no ordering implied (symmetric in intent)
///
/// We store one row per directed edge (no auto-inverse). Read-side UI
/// computes "Blocked by"/"Spawned by" by looking at incoming edges. Composite
/// unique prevents accidental duplicate links.
model AdminTodoDependency {
  id        String    @id @default(cuid())
  fromId    String
  toId      String
  type      String
  createdAt DateTime  @default(now())
  from      AdminTodo @relation("DepFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        AdminTodo @relation("DepTo",   fields: [toId],   references: [id], onDelete: Cascade)

  @@unique([fromId, toId, type])
  @@index([toId, type])
  @@index([fromId, type])
}

/// Tracks alerts generated by Gemma's RAG and monitoring engine
model GemmaAlert {
  id             String    @id @default(cuid())
  type           String    // "INTEGRITY" | "MODERATION" | "SYSTEM_STALL" | "SECURITY"
  title          String
  body           String
  severity       String    @default("MEDIUM") // "LOW" | "MEDIUM" | "HIGH" | "CRITICAL"
  status         String    @default("UNRESOLVED") // "UNRESOLVED" | "DISMISSED" | "RESOLVED"
  proposedAction String?   // JSON text of suggested action payload
  targetId       String?   // Reference ID for polymorphic associations (user, post, attempt, etc.)
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  @@index([status, severity])
  @@index([type, status])
}

// ── Phase 4: creator marketplace ─────────────────────────────────────────────
// Creators (CREATOR role) sell exclusive content — challenges, blog posts,
// snippets — one-time or by subscription, paid through Stripe Connect with a
// platform fee. Access is gated by Entitlement rows (see src/lib/marketplace).

/// A creator's Stripe Connect (Express) account. `chargesEnabled` gates the
/// ability to publish products — a half-onboarded creator can't list yet.
model CreatorAccount {
  id              String    @id @default(cuid())
  userId          String    @unique
  stripeAccountId String?   @unique
  chargesEnabled  Boolean   @default(false)
  payoutsEnabled  Boolean   @default(false)
  onboardedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

/// A creator's branded space — a workspace-like hub published at /c/[handle].
/// One space per creator (v1). Holds tiers, content, and memberships.
model CreatorSpace {
  id          String   @id @default(cuid())
  ownerId     String
  /// Vanity slug → /c/[handle].
  handle      String   @unique
  name        String
  tagline     String?
  /// Markdown "about" section.
  description String?
  avatarUrl   String?
  coverUrl    String?
  /// Public-page layout: hero style + ordered section visibility. Shape:
  /// { heroStyle: "banner"|"minimal", sections: [{ key, visible }] }.
  layout      Json?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// A ranked membership tier within a space. Higher `rank` = more access: an
/// active subscriber sees SpaceContent with accessTierRank ≤ their tier's rank.
/// platformFeeBps is the platform's cut in basis points (2000 = 20%).
model SpaceTier {
  id              String  @id @default(cuid())
  spaceId         String
  name            String
  rank            Int
  priceCents      Int
  currency        String  @default("usd")
  platformFeeBps  Int     @default(2000)
  stripeProductId String?
  /// Recurring (monthly) Stripe price id.
  stripePriceId   String?
  published       Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([spaceId, rank])
  @@index([spaceId])
}

/// Per-user one-time access grant to a piece of content. `source` records why
/// (a one-time purchase or an admin grant). Subscription access is resolved live
/// from SpaceMembership, not stored here.
model Entitlement {
  id          String    @id @default(cuid())
  userId      String
  contentType String
  contentId   String
  /// "PURCHASE" | "GRANT"
  source      String
  /// The SpaceContent row this purchase was for (informational).
  spaceContentId String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userId, contentType, contentId])
  @@index([userId])
}

/// A buyer's active subscription to a space at a given tier rank. While
/// `status` is active they reach all SpaceContent with accessTierRank ≤ tierRank.
model SpaceMembership {
  id                   String    @id @default(cuid())
  subscriberId         String
  spaceId              String
  /// Snapshot of the subscribed tier's rank (drives access).
  tierRank             Int
  stripeSubscriptionId String    @unique
  /// Stripe subscription status: "active" | "canceled" | "past_due" | ...
  status               String
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([subscriberId, spaceId])
  @@index([spaceId])
  @@index([subscriberId, status])
}

/// Idempotent ledger of creator earnings — one row per paid sale, split into
/// gross / platform fee / net. Unique on stripeChargeId so webhook redelivery
/// can't double-record (same pattern as recordPurchase in ai-interview/credits).
model CreatorEarning {
  id             String   @id @default(cuid())
  creatorId      String
  /// "TIER" | "CONTENT" — what produced this earning.
  sourceKind     String?
  /// SpaceTier.id or SpaceContent.id depending on sourceKind (informational).
  sourceId       String?
  buyerId        String?
  grossCents     Int
  feeCents       Int
  netCents       Int
  currency       String   @default("usd")
  stripeChargeId String   @unique
  status         String   @default("paid")
  createdAt      DateTime @default(now())

  @@index([creatorId])
}

/// First-class tutorial — a multi-section lesson authored in a space.
model Tutorial {
  id         String            @id @default(cuid())
  spaceId    String
  authorId   String
  slug       String
  title      String
  summary    String?
  coverImage String?
  published  Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  sections   TutorialSection[]

  @@unique([spaceId, slug])
  @@index([spaceId])
}

/// One ordered section of a tutorial. May embed an existing snippet/challenge.
model TutorialSection {
  id          String   @id @default(cuid())
  tutorialId  String
  position    Int
  title       String?
  /// Markdown body.
  body        String
  snippetId   String?
  challengeId String?
  tutorial    Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  @@index([tutorialId])
}

/// First-class interview Q&A page — a titled collection of question/answer items.
model InterviewQA {
  id        String              @id @default(cuid())
  spaceId   String
  authorId  String
  slug      String
  title     String
  summary   String?
  category  String?
  published Boolean             @default(false)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  questions InterviewQuestion[]

  @@unique([spaceId, slug])
  @@index([spaceId])
}

model InterviewQuestion {
  id         String      @id @default(cuid())
  qaId       String
  position   Int
  question   String
  /// Markdown answer.
  answer     String
  difficulty String?
  qa         InterviewQA @relation(fields: [qaId], references: [id], onDelete: Cascade)

  @@index([qaId])
}

/// First-class interview experience — a narrative writeup of a real interview
/// (company / role / outcome + a markdown story). Authored in a space, gated
/// via SpaceContent like any other ownable content type.
model InterviewExperience {
  id         String   @id @default(cuid())
  spaceId    String
  authorId   String
  slug       String
  title      String
  company    String?
  role       String?
  /// "offer" | "rejected" | "pending" | "withdrew"
  outcome    String?
  /// "easy" | "medium" | "hard"
  difficulty String?
  summary    String?
  /// Markdown body — the full experience writeup.
  body       String
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([spaceId, slug])
  @@index([spaceId])
}

/// ── Interview Questions module (public/SEO question bank) ──────────────────
/// Distinct from the creator-space InterviewQA/InterviewQuestion/Interview-
/// Experience models above: these are a centralized, admin-curated, company-
/// indexed repository powering /interview-questions and its SEO pages. "Prep"
/// namespace avoids the name collision with the creator-space models.

/// A hiring company that questions and experiences are indexed under.
model Company {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  logo        String?
  description String?
  website     String?
  industry    String?
  /// JSON string[] of frequently-asked roles, e.g. ["SDE","Frontend"].
  hiringRoles String           @default("[]")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  questions   PrepQuestion[]
  experiences PrepExperience[]

  @@index([slug])
}

/// One interview-prep question. May be tied to a company and/or a technology.
model PrepQuestion {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  /// The question body / prompt (markdown).
  description     String?
  /// Markdown answer / explanation.
  answer          String?
  companyId       String?
  /// Slug-like tech tag the technology pages key off, e.g. "reactjs".
  technology      String?
  role            String?
  /// "easy" | "medium" | "hard"
  difficulty      String   @default("medium")
  /// Interview round, e.g. "DSA" | "System Design" | "HR".
  round           String?
  /// "fresher" | "mid" | "senior"
  experienceLevel String?
  /// JSON string[] of free-form tags.
  tags            String   @default("[]")
  /// JSON number[] of years the question was reportedly asked.
  yearsAsked      String   @default("[]")
  views           Int      @default(0)
  likes           Int      @default(0)
  /// "draft" | "published" | "archived"
  status          String   @default("draft")
  seoTitle        String?
  seoDescription  String?
  /// Cached AI-generated hint (nudge, not the full answer). Generated lazily on
  /// first request and reused thereafter to bound LLM cost.
  aiHint          String?
  /// JSON array of runnable code examples: [{ label, code }]. Rendered as
  /// interactive playgrounds on the question page (currently JS-executable).
  examplesData    String?
  /// JSON map of per-framework tutorial bundles for machine-coding questions:
  /// { react|vue|angular: { answer, files } }. When present, the detail page
  /// shows a framework selector that swaps both the tutorial and the runnable
  /// solution. `answer`/`examplesData` hold the default (React) for SSR/SEO.
  frameworksData  String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company?              @relation(fields: [companyId], references: [id], onDelete: SetNull)
  comments        PrepQuestionComment[]
  savedByUsers    User[]                @relation("UserSavedPrepQuestions")
  solvedByUsers   User[]                @relation("UserSolvedPrepQuestions")

  @@index([companyId])
  @@index([technology, status])
  @@index([status])
  @@index([slug])
}

/// A user discussion comment on an interview-prep question.
model PrepQuestionComment {
  id         String       @id @default(cuid())
  questionId String
  userId     String
  content    String
  createdAt  DateTime     @default(now())
  question   PrepQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([userId])
}

/// A real interview experience writeup, optionally moderated before publishing.
model PrepExperience {
  id              String   @id @default(cuid())
  companyId       String?
  /// Denormalized company name for display when no company row is linked.
  companyName     String?
  role            String?
  experienceLevel String?
  location        String?
  year            Int?
  /// Markdown overview of the interview process.
  process         String?
  /// Markdown / freeform description of the rounds.
  rounds          String?
  /// JSON string[] of questions asked (titles or PrepQuestion slugs).
  questionsAsked  String   @default("[]")
  /// "selected" | "rejected" | "pending"
  result          String?
  /// Markdown tips for future candidates.
  tips            String?
  difficulty      String?
  /// "pending" | "approved" | "published" | "rejected"
  status          String   @default("pending")
  authorId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
}

/// A user's guided interview-prep plan: a generated day-by-day curriculum of
/// interview questions + challenges for a chosen role/tech stack. One ACTIVE
/// journey per user is enforced in the API layer (pause/archive to start
/// another), not by a schema constraint.
model PrepJourney {
  id           String            @id @default(cuid())
  userId       String
  title        String
  /// "frontend" | "backend" | "fullstack" | "ai-ready" | "custom"
  role         String
  /// JSON string[] of technology slugs (TECHNOLOGIES in interview-questions/shared).
  techStack    String            @default("[]")
  /// Daily study budget in minutes (15 | 30 | 45 | 60).
  dailyMinutes Int               @default(30)
  /// Total planned days, fixed at generation time.
  totalDays    Int
  /// Optional target interview date the plan length was fitted to.
  targetDate   DateTime?
  /// IANA timezone captured at creation — daily boundaries, streaks and the
  /// heatmap are computed in this zone, not the server's.
  timezone     String            @default("UTC")
  /// "active" | "paused" | "completed" | "archived"
  status       String            @default("active")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        PrepJourneyItem[]

  @@index([userId, status])
}

/// One scheduled item (question or challenge) inside a journey's day plan.
/// Completion is written by the same signals users already emit elsewhere
/// (question Mark-Solved, passing challenge submit) — the tracker never asks
/// for duplicate check-offs.
model PrepJourneyItem {
  id          String      @id @default(cuid())
  journeyId   String
  /// 1-based day index within the journey.
  day         Int
  /// Order within the day.
  position    Int
  /// "question" | "challenge" | "scenario"
  itemType    String
  /// PrepQuestion.slug, Challenge.slug, or PromptScenario.slug.
  refSlug     String
  /// Denormalized display fields so the tracker renders without joining two
  /// content tables per row.
  title       String
  technology  String?
  difficulty  String?
  /// Estimated minutes — drives the daily fill and PrepActivity minutes.
  estMinutes  Int         @default(8)
  completedAt DateTime?
  journey     PrepJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@index([journeyId, day, position])
  @@index([journeyId, refSlug])
}

/// One row per user per local calendar day with any prep activity — powers
/// streaks and the heatmap. Needed because the solved M2M relation carries no
/// timestamps.
model PrepActivity {
  id      String @id @default(cuid())
  userId  String
  /// "YYYY-MM-DD" in the journey's timezone.
  date    String
  minutes Int    @default(0)
  items   Int    @default(0)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

/// Polymorphic access index: ties any content type to a space + its access
/// policy. Replaces the flat Phase-4 Product. `accessTierRank` null = free;
/// otherwise the minimum membership tier rank. `purchasePriceCents` (when set)
/// also allows a one-time buy that grants a permanent Entitlement.
model SpaceContent {
  id                 String   @id @default(cuid())
  spaceId            String
  /// CHALLENGE | SNIPPET | BLOG_POST | TUTORIAL | INTERVIEW_QA
  contentType        String
  contentId          String
  accessTierRank     Int?
  purchasePriceCents Int?
  currency           String   @default("usd")
  platformFeeBps     Int      @default(2000)
  stripeProductId    String?
  stripePriceId      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([contentType, contentId])
  @@index([spaceId])
}

/// A user's request to become a creator. Gated on a follower threshold
/// (1000+ on YouTube/LinkedIn), verified manually by a reviewer holding the
/// `creator:review` permission. Approval grants the CREATOR role. One row per
/// user — a rejected applicant can resubmit (the row flips back to PENDING).
model CreatorApplication {
  id            String    @id @default(cuid())
  userId        String    @unique
  /// "youtube" | "linkedin"
  platform      String
  profileUrl    String
  /// Self-reported follower/subscriber count (reviewer verifies the link).
  followerCount Int
  note          String?
  /// "PENDING" | "APPROVED" | "REJECTED"
  status        String    @default("PENDING")
  reviewerId    String?
  reviewNote    String?
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?
  updatedAt     DateTime  @updatedAt

  @@index([status])
}

