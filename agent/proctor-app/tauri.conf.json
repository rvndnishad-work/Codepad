{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InterviewPad Proctor",
  "version": "0.1.0",
  "identifier": "dev.interviewpad.proctor",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "InterviewPad Screen Proctor",
        "width": 540,
        "height": 700,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "shortDescription": "Consent-based interview screen proctor",
    "longDescription": "Detects overlay AI-assist tools during an interview, with the candidate's consent. Removes itself when the session ends."
  }
}
